# Удалённый Alem Plus (опционально). Если задан URL — POST /v1/alem/pipeline уходит сюда;
# при ошибке или отсутствии URL работает локальный C-VAE + mock Qazaq/TTS.
ALEM_PLUS_BASE_URL=
ALEM_PLUS_API_KEY=
# Путь относительно BASE (по умолчанию как у локального API)
ALEM_PLUS_PIPELINE_PATH=/v1/alem/pipeline
ALEM_PLUS_TIMEOUT_SEC=20
