# Local environment variables for Vite
# Copy this file to .env and fill in the values for local development.

# --- FRONTEND (Vite) ---
# URL для Alem Plus API (обычно https://llm.alem.ai/v1)
VITE_ALEM_API_URL=https://llm.alem.ai/v1
# Секретный ключ, который вы получили в платформе Alem Plus
VITE_ALEM_API_KEY=your_alem_api_key_here

# --- BACKEND (Optional for Vercel) ---
BACKEND_URL=https://your-backend-url.vercel.app
ALEM_PLUS_BASE_URL=https://llm.alem.ai/v1
ALEM_PLUS_TOKEN=your_alem_token_here
ALEM_PLUS_MODEL=alemllm
